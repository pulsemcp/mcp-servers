# Aetna Claims MCP Server Configuration

# Required: Your Aetna account credentials
AETNA_USERNAME=your-username
AETNA_PASSWORD=your-password

# Required: Email credentials for receiving 2FA codes
# For Gmail, use an app-specific password (https://myaccount.google.com/apppasswords)
EMAIL_IMAP_USER=your-email@gmail.com
EMAIL_IMAP_PASSWORD=your-app-password

# Optional: IMAP server settings (defaults to Gmail)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993

# Optional: Run browser in headless mode (default: true)
HEADLESS=true

# Optional: Browser operation timeout in milliseconds (default: 30000)
TIMEOUT=30000

# Optional: Directory to save downloaded documents (default: /tmp/aetna-downloads)
AETNA_DOWNLOAD_DIR=/tmp/aetna-downloads
