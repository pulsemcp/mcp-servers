# Example environment variables for PulseMCP CMS Admin MCP Server
# Copy this file to .env and fill in your actual values

# Required: PulseMCP Admin API key for authentication
PULSEMCP_ADMIN_API_KEY=your-api-key-here

# Required for manual tests: Point to staging API (NOT production)
# Manual tests MUST run against staging. The default (admin.pulsemcp.com) is production.
PULSEMCP_ADMIN_API_URL=https://admin.staging.pulsemcp.com
