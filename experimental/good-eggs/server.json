{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "com.pulsemcp/good-eggs",
  "description": "MCP server for Good Eggs grocery shopping automation using Playwright.",
  "version": "0.1.10",
  "repository": {
    "url": "https://github.com/pulsemcp/mcp-servers",
    "source": "github",
    "subfolder": "experimental/good-eggs"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "good-eggs-mcp-server",
      "version": "0.1.10",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        }
      ],
      "environmentVariables": [
        {
          "name": "GOOD_EGGS_USERNAME",
          "description": "Your Good Eggs account email address.",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "GOOD_EGGS_PASSWORD",
          "description": "Your Good Eggs account password.",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "HEADLESS",
          "description": "Run browser in headless mode (true/false).",
          "default": "true",
          "isRequired": false
        },
        {
          "name": "TIMEOUT",
          "description": "Browser operation timeout in milliseconds.",
          "default": "30000",
          "isRequired": false
        }
      ]
    }
  ]
}
