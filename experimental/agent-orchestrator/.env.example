# Example environment variables for manual testing
# Copy this file to .env and fill in your actual values

# Required: Base URL for the Agent Orchestrator API
# Tests default to staging. For production, use https://ao.pulsemcp.com
AGENT_ORCHESTRATOR_BASE_URL=https://ao.staging.pulsemcp.com

# Required: API key for authentication
AGENT_ORCHESTRATOR_API_KEY=your-api-key-here

# Optional: Comma-separated list of tool groups to enable
# TOOL_GROUPS=sessions,notifications

# Optional: Skip health checks at startup
# SKIP_HEALTH_CHECKS=true
