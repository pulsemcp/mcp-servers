{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "com.pulsemcp/serpapi-hotels",
  "description": "MCP server for searching Google Hotels via SerpAPI — hotel search, pricing, ratings, and reviews.",
  "version": "0.0.4",
  "repository": {
    "url": "https://github.com/pulsemcp/mcp-servers",
    "source": "github",
    "subfolder": "experimental/serpapi-hotels"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "serpapi-hotels-mcp-server",
      "version": "0.0.4",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        }
      ],
      "environmentVariables": [
        {
          "name": "SERPAPI_API_KEY",
          "description": "Your SerpAPI API key for hotel search access.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
