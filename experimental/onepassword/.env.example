# Environment variables for 1Password MCP Server
# Copy this file to .env and fill in your actual values

# Required: 1Password Service Account Token
# Create one at: https://developer.1password.com/docs/service-accounts/
OP_SERVICE_ACCOUNT_TOKEN=ops_your-service-account-token-here

# Optional: Limit which tools are available
# ENABLED_TOOLGROUPS=readonly

# Optional: Skip health checks on startup
# SKIP_HEALTH_CHECKS=true

# =============================================================================
# ELICITATION CONFIGURATION
# =============================================================================
# Controls whether the server asks for user confirmation before sensitive operations.
#
# The server requires elicitation to be configured before it will start.
# If no elicitation mechanism is available, set DANGEROUSLY_SKIP_ELICITATIONS=true
# to explicitly opt out (all secrets will be accessible without user approval).

# Explicitly opt out of ALL confirmation prompts (default: not set)
# WARNING: When set to "true", all secrets are accessible without user approval.
# Only use this for fully automated workflows where you trust all connected clients.
# DANGEROUSLY_SKIP_ELICITATIONS=true

# NOTE: ELICITATION_ENABLED is NOT supported by this server.
# Use DANGEROUSLY_SKIP_ELICITATIONS=true instead to disable confirmations.

# Per-action elicitation overrides (default: true)
# OP_ELICITATION_READ=true    # Prompt before revealing credentials in get_item
# OP_ELICITATION_WRITE=true   # Prompt before creating items (create_login, create_secure_note)

# Comma-separated list of item titles or item IDs that bypass read elicitation (case-insensitive)
# Useful for workflows that always need specific credentials
# Each entry can be a title (e.g., "Stripe Key") or an item ID (e.g., "abc123def456")
# OP_WHITELISTED_ITEMS=Stripe Key,AWS Credentials,abc123def456

# HTTP fallback for elicitation (when MCP client doesn't support native elicitation)
# ELICITATION_REQUEST_URL=https://your-approval-endpoint.com/request
# ELICITATION_POLL_URL=https://your-approval-endpoint.com/poll
# ELICITATION_TTL_MS=300000
# ELICITATION_POLL_INTERVAL_MS=5000
# ELICITATION_SESSION_ID=your-session-id
