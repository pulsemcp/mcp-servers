{
  "name": "@pulsemcp/image-diff-mcp-server",
  "version": "0.1.1",
  "description": "MCP server for programmatic image comparison and visual diff generation",
  "mcpName": "com.pulsemcp.servers/image-diff",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "@pulsemcp/image-diff-mcp-server": "./build/index.js"
  },
  "files": [
    "build/**/*.js",
    "build/**/*.d.ts",
    "shared/**/*.js",
    "shared/**/*.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsx src/index.ts",
    "predev": "cd ../shared && npm run build && cd ../local && node setup-dev.js",
    "prebuild": "cd ../shared && npm run build && cd ../local && node setup-dev.js",
    "prepublishOnly": "node prepare-publish.js",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stage-publish": "npm version"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "opencv-wasm": "^4.3.0-10",
    "sharp": "^0.33.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  },
  "keywords": [],
  "author": "PulseMCP",
  "license": "MIT"
}
